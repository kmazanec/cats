# --- LLM provider ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Observability ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cats-dev
LANGSMITH_TRACING=true

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://cats:cats@localhost:5433/cats
REDIS_URL=redis://localhost:6380/0

# --- Target (default project seeded by `make smoke`) ---
DEFAULT_TARGET_NAME=Local Co-Pilot
DEFAULT_TARGET_BASE_URL=http://localhost:8300
DEFAULT_TARGET_ENV=local

# --- API ---
CATS_API_HOST=0.0.0.0
CATS_API_PORT=8400
CATS_LOG_LEVEL=INFO

# --- Auth (R1) ---
# Bootstrap admin — seeded into the users table on first startup if absent.
CATS_ADMIN_EMAIL=admin@example.com
CATS_ADMIN_PASSWORD=change-me-at-least-8-chars
# Sign session cookies. Generate with: openssl rand -hex 32
CATS_SESSION_SECRET=dev-session-secret-change-me
# Optional: session lifetime (default = 7 days).
# CATS_SESSION_MAX_AGE_SECONDS=604800

# --- Build / deploy metadata (set by GitLab CI) ---
# Override locally if you want the chrome to show a specific tag.
# CATS_BUILD_SHA=dev
# CATS_GITLAB_PIPELINE_URL=
